# Enhanced Inventory Management Program
# Improvements:
# - Added error handling for user input
# - Added input validation
# - Improved structure with main() function
# - Added comments for readability and maintainability
# - Minor design improvements for better user experience

# Global inventory list
inventory = []

def add_item():
    # Get item name and validate
    name = input("Enter item name: ").strip()
    if name == "":
        print("Item name cannot be empty.\n")
        return

    # Error handling for quantity input
    try:
        quantity = int(input("Enter quantity: "))
    except ValueError:
        print("Invalid input. Please enter a numeric value.\n")
        return

    # Store item as dictionary (kept original structure for consistency)
    inventory.append({"name": name, "quantity": quantity})
    print("Item added successfully.\n")

def view_inventory():
    # Check if inventory is empty
    if len(inventory) == 0:
        print("Inventory is empty.\n")
        return

    # Display all items
    print("\nCurrent Inventory:")
    for item in inventory:
        print(f"{item['name']} - {item['quantity']}")
    print()

def sort_inventory():
    # Check if inventory is empty before sorting
    if len(inventory) == 0:
        print("Inventory is empty.\n")
        return

    # Sort inventory by item name
    sorted_list = sorted(inventory, key=lambda x: x["name"])

    print("\nSorted Inventory (by name):")
    for item in sorted_list:
        print(f"{item['name']} - {item['quantity']}")
    print()

def search_item():
    # Get search input
    search = input("Enter item name to search: ").strip()

    # Validate input
    if search == "":
        print("Search term cannot be empty.\n")
        return

    # Perform case-insensitive search
    for item in inventory:
        if item["name"].lower() == search.lower():
            print(f"Found: {item['name']} - {item['quantity']}\n")
            return

    print("Item not found.\n")

def menu():
    # Main program loop
    while True:
        print("1. Add Item")
        print("2. View Inventory")
        print("3. Sort Inventory")
        print("4. Search Item")
        print("5. Exit")

        choice = input("Choose option: ")

        if choice == "1":
            add_item()
        elif choice == "2":
            view_inventory()
        elif choice == "3":
            sort_inventory()
        elif choice == "4":
            search_item()
        elif choice == "5":
            print("Exiting program.")
            break
        else:
            print("Invalid option. Please try again.\n")

# Entry point for program (improves structure and readability)
def main():
    menu()

# Ensures program runs only when executed directly
if __name__ == "__main__":
    main()
